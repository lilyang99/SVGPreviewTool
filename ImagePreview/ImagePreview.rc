/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU
BEGIN
    POPUP "File(&F)"
    BEGIN
        MENUITEM "Open(&O)...\tCtrl+O",         ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "Recent Files",                ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "Exit(&X)",                    ID_APP_EXIT
    END
    POPUP "Zoom(&Z)"
    BEGIN
        MENUITEM "100%",                        ID_ZOOM_100
        MENUITEM "125%",                        ID_ZOOM_125
        MENUITEM "150%",                        ID_ZOOM_150
        MENUITEM "175%",                        ID_ZOOM_175
        MENUITEM "200%",                        ID_ZOOM_200
        MENUITEM "225%",                        ID_ZOOM_225
        MENUITEM "250%",                        ID_ZOOM_250
        MENUITEM "300%",                        ID_ZOOM_300
        MENUITEM SEPARATOR
        MENUITEM "DPI Scale...",                ID_DPI_SCALE
        MENUITEM "Clear Scale",                 ID_ZOOM_CLEAR
    END
    POPUP "Icon Size(&I)"
    BEGIN
        MENUITEM "Default",                     ID_ICON_DEFAULT
        MENUITEM "16x16",                       ID_ICON_16
        MENUITEM "32x32",                       ID_ICON_32
        MENUITEM "48x48",                       ID_ICON_48
        MENUITEM "64x64",                       ID_ICON_64
        MENUITEM "128x128",                     ID_ICON_128
        MENUITEM "256x256",                     ID_ICON_256
        MENUITEM "Custom...",                   ID_ICON_CUSTOM
    END
    POPUP "Help(&H)"
    BEGIN
        MENUITEM "About ImagePreview(&A)...", ID_APP_ABOUT
    END
END


